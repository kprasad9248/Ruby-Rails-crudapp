<h1 class="text-center" >View Student Details</h1>

<div class="d-flex justify-content-center mt-5">
  <div class="card text-center p-4 w-50">
    <h2 class="mb-3">
      <strong>Name:</strong> <%= @student.name %>
    </h2>
    <p><strong>Age:</strong> <%= @student.age %></p>
    <p><strong>Gender:</strong> <%= @student.gender %></p>
    <p><strong>Marks:</strong> <%= @student.marks %></p>

    <div class="mt-4 d-flex justify-content-center gap-2">
      <%= link_to "Back", students_path, class: "btn btn-secondary" %>
      <%= link_to "Edit", edit_student_path(@student), class: "btn btn-warning" %>
      <%= button_to "Delete", student_path(@student), method: :delete,data: { turbo_confirm: "Are you sure?" },class: "btn btn-danger" %>
    </div>
  </div>
</div>

